{
  "expo": {
    "name": "V-Cut Luxe",
    "slug": "v-cuterp-mob",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "vcut",
    "splash": {
      "backgroundColor": "#0a0806",
      "resizeMode": "contain"
    },
    "android": {
      "package": "com.vcut.luxe",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0a0806"
      },
      "permissions": ["INTERNET"]
    },
    "ios": {
      "bundleIdentifier": "com.vcut.luxe",
      "supportsTablet": false
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
